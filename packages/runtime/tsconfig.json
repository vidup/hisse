{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts", "application/**/*.ts", "domain/**/*.ts", "infrastructure/**/*.ts"],
  "exclude": ["**/*.test.ts", "dist", "node_modules"]
}
